{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DuckDB Grammar",
  "scopeName": "source.duckdb-gram",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#rule-header"
    },
    {
      "include": "#literal"
    },
    {
      "include": "#regex"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#references"
    }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.duckdb-gram",
      "match": "#.*$"
    },
    "rule-header": {
      "patterns": [
        {
          "name": "meta.rule.header.parameterized.duckdb-gram",
          "match": "^(\\s*)(%?[A-Za-z][A-Za-z0-9_]*)(\\s*)(\\()([A-Za-z0-9_]+)(\\))(\\s*)(<-)",
          "captures": {
            "2": {
              "name": "entity.name.function.rule.duckdb-gram"
            },
            "4": {
              "name": "punctuation.section.parameters.begin.duckdb-gram"
            },
            "5": {
              "name": "variable.parameter.duckdb-gram"
            },
            "6": {
              "name": "punctuation.section.parameters.end.duckdb-gram"
            },
            "8": {
              "name": "keyword.operator.assignment.duckdb-gram"
            }
          }
        },
        {
          "name": "meta.rule.header.duckdb-gram",
          "match": "^(\\s*)(%?[A-Za-z][A-Za-z0-9_]*)(\\s*)(<-)",
          "captures": {
            "2": {
              "name": "entity.name.function.rule.duckdb-gram"
            },
            "4": {
              "name": "keyword.operator.assignment.duckdb-gram"
            }
          }
        }
      ]
    },
    "literal": {
      "name": "string.quoted.single.duckdb-gram",
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.duckdb-gram"
        }
      },
      "end": "'",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.duckdb-gram"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.duckdb-gram",
          "match": "\\\\."
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "name": "string.regexp.character-class.duckdb-gram",
          "match": "\\[(?:\\\\.|[^\\]])*\\]"
        },
        {
          "name": "string.regexp.named.duckdb-gram",
          "match": "<(?!-)(?:\\\\.|[^>])+>"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.choice.duckdb-gram",
          "match": "/"
        },
        {
          "name": "keyword.operator.quantifier.duckdb-gram",
          "match": "[?*+]"
        },
        {
          "name": "keyword.operator.negation.duckdb-gram",
          "match": "!"
        },
        {
          "name": "punctuation.section.group.begin.duckdb-gram",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.duckdb-gram",
          "match": "\\)"
        }
      ]
    },
    "references": {
      "name": "variable.other.rule-reference.duckdb-gram",
      "match": "\\b[A-Za-z][A-Za-z0-9_]*\\b"
    }
  }
}
